@* Learning edition Razor view: comments explain how the page is assembled step by step. *@
@* Declares the view model type that this page expects. *@
@model Client
@* Starts a Razor code block for page-level setup. *@
@{
    @* Sets the page title used by the browser and layout. *@
    ViewData["Title"] = "Create Client";
}
@* Creates a visual container to group related content. *@
<div class="card">
    @* Displays content to the user in a readable format. *@
    <h1>Create Client</h1>
    @* Begins a form that sends user input back to the controller. *@
    <form asp-action="Create" method="post" class="form-stack">
        @Html.AntiForgeryToken()
        @* Creates a visual container to group related content. *@
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        @* Shows the label that explains what the input is for. *@
        <label asp-for="Name"></label>
        @* Renders an input control so the user can enter or choose data. *@
        <input asp-for="Name" />

        @* Shows the label that explains what the input is for. *@
        <label asp-for="ContactDetails"></label>
        @* Renders an input control so the user can enter or choose data. *@
        <input asp-for="ContactDetails" />

        @* Shows the label that explains what the input is for. *@
        <label asp-for="Region"></label>
        @* Renders an input control so the user can enter or choose data. *@
        <input asp-for="Region" />

        <button type="submit" class="btn">Save</button>
    </form>
@* Creates a visual container to group related content. *@
</div>
