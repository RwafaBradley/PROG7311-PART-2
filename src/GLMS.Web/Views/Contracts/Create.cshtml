@* Learning edition Razor view: comments explain how the page is assembled step by step. *@
@* Declares the view model type that this page expects. *@
@model ContractCreateViewModel
@* Starts a Razor code block for page-level setup. *@
@{
    @* Sets the page title used by the browser and layout. *@
    ViewData["Title"] = "Create Contract";
}
@* Creates a visual container to group related content. *@
<div class="card">
    @* Displays content to the user in a readable format. *@
    <h1>Create Contract</h1>

    @* Begins a form that sends user input back to the controller. *@
    <form asp-action="Create" method="post" enctype="multipart/form-data" class="form-stack">
        @Html.AntiForgeryToken()
        @* Creates a visual container to group related content. *@
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        @* Shows the label that explains what the input is for. *@
        <label asp-for="ClientId"></label>
        @* Renders an input control so the user can enter or choose data. *@
        <select asp-for="ClientId" asp-items="Model.Clients">
            <option value="">Choose a client</option>
        </select>

        @* Shows the label that explains what the input is for. *@
        <label asp-for="ContractNumber"></label>
        @* Renders an input control so the user can enter or choose data. *@
        <input asp-for="ContractNumber" />

        @* Shows the label that explains what the input is for. *@
        <label asp-for="StartDate"></label>
        @* Renders an input control so the user can enter or choose data. *@
        <input asp-for="StartDate" type="date" />

        @* Shows the label that explains what the input is for. *@
        <label asp-for="EndDate"></label>
        @* Renders an input control so the user can enter or choose data. *@
        <input asp-for="EndDate" type="date" />

        @* Shows the label that explains what the input is for. *@
        <label asp-for="Status"></label>
        @* Renders an input control so the user can enter or choose data. *@
        <select asp-for="Status" asp-items="Html.GetEnumSelectList<ContractStatus>()"></select>

        @* Shows the label that explains what the input is for. *@
        <label asp-for="ServiceLevel"></label>
        @* Renders an input control so the user can enter or choose data. *@
        <input asp-for="ServiceLevel" />

        @* Shows the label that explains what the input is for. *@
        <label asp-for="SignedAgreement">Signed Agreement (PDF only)</label>
        @* Renders an input control so the user can enter or choose data. *@
        <input asp-for="SignedAgreement" type="file" accept=".pdf" />

        <button type="submit" class="btn">Save</button>
    </form>
@* Creates a visual container to group related content. *@
</div>
